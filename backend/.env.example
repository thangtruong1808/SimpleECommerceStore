ConnectionStrings__DefaultConnection=Server=localhost;Port=3306;Database=SimpleECommerce;User=root;Password=your_password;
JWT__Secret=your-256-bit-secret-key-here-min-32-characters
JWT__Issuer=SimpleECommerceStore
JWT__Audience=SimpleECommerceStore
JWT__AccessTokenExpirationMinutes=15
JWT__RefreshTokenExpirationDays=7
Auth__ReturnResetTokenInDev=true
FrontendBaseUrl=http://localhost:5173
ASPNETCORE_ENVIRONMENT=Development
  
